{
  "info": {
    "name": "Core Profile API",
    "description": "Postman collection for testing the Core Profile API endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health / API Metadata",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/",
          "host": ["{{baseUrl}}"],
          "path": [""]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"returns API metadata\", function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.message).to.eql(\"Core Profile API\");",
              "  pm.expect(json.endpoints.profile).to.eql(\"/api/profile\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Full Profile",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/profile",
          "host": ["{{baseUrl}}"],
          "path": ["api", "profile"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"returns full profile\", function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.success).to.eql(true);",
              "  pm.expect(json.data).to.have.property(\"hero\");",
              "  pm.expect(json.data).to.have.property(\"timeline\");",
              "  pm.expect(json.data).to.have.property(\"workSamples\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Work Samples Section",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/profile/workSamples",
          "host": ["{{baseUrl}}"],
          "path": ["api", "profile", "workSamples"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"returns workSamples section\", function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.success).to.eql(true);",
              "  pm.expect(json.section).to.eql(\"workSamples\");",
              "  pm.expect(json.data).to.have.property(\"githubProjects\");",
              "  pm.expect(json.data).to.have.property(\"specificationSamples\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Background Section",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/profile/background",
          "host": ["{{baseUrl}}"],
          "path": ["api", "profile", "background"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"returns background section\", function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.success).to.eql(true);",
              "  pm.expect(json.section).to.eql(\"background\");",
              "  pm.expect(json.data).to.have.property(\"credentials\");",
              "  pm.expect(json.data).to.have.property(\"education\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Domains Section",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/profile/domains",
          "host": ["{{baseUrl}}"],
          "path": ["api", "profile", "domains"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"returns domains section\", function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.success).to.eql(true);",
              "  pm.expect(json.section).to.eql(\"domains\");",
              "  pm.expect(json.data).to.have.property(\"items\");",
              "  pm.expect(json.data.items.length).to.be.above(0);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Background Alias Section",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/profile/backgrond",
          "host": ["{{baseUrl}}"],
          "path": ["api", "profile", "backgrond"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"maps backgrond alias to background\", function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.success).to.eql(true);",
              "  pm.expect(json.section).to.eql(\"background\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Unknown Section",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/profile/unknown",
          "host": ["{{baseUrl}}"],
          "path": ["api", "profile", "unknown"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"status is 404\", function () {",
              "  pm.response.to.have.status(404);",
              "});",
              "",
              "pm.test(\"returns available sections\", function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.success).to.eql(false);",
              "  pm.expect(json.availableSections).to.include(\"workSamples\");",
              "  pm.expect(json.availableSections).to.include(\"background\");",
              "  pm.expect(json.availableSections).to.include(\"domains\");",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
